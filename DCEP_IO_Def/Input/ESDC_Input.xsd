<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"  elementFormDefault="qualified" attributeFormDefault="unqualified" dcep_version="20191025">
	<xs:element name="Satellite_parameters"> 
		<xs:complexType>
			<xs:sequence>
				<xs:element name="input_case" minOccurs="2" maxOccurs="unbounded">
